---
import Layout from '../layout/Layout.astro';
import EntryCard from '../components/EntryCard.astro';
import DateCard from '../components/DateCard.astro';
import MoodCard from '../components/MoodCard.astro';
import QuoteCard from '../components/QuoteCard.astro';
import StreakCard from '../components/StreakCard.astro';
import ThemesCard from '../components/ThemesCard.astro';
import RecentCard from '../components/RecentCard.astro';
---

<Layout title="Mind Diary">
  <header>
	<h1>Mind Diary</h1>
	<p class="subtitle">YOUR THOUGHTS, BEAUTIFULLY KEPT</p>
  </header>

  <main class="bento">
	<EntryCard />
	<DateCard />
	<MoodCard />
	<QuoteCard />
	<StreakCard />
	<ThemesCard />
	<RecentCard />
  </main>
</Layout>

<style>
  header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-family: 'Dancing Script', cursive;
    font-size: 3rem;
    color: var(--warm-brown);
    line-height: 1;
  }

  .subtitle {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--warm-muted);
    margin-top: 4px;
  }

  .bento {
    display: grid;
    width: 100%;
    max-width: 820px;
    grid-template-columns: 1.4fr 1fr 1fr;
    grid-template-rows: auto auto auto;
    gap: 10px;
  }
</style>